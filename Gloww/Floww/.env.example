# ── LLM Provider ─────────────────────────────────────────────────────────────
# Pick ONE provider + set the matching key below.
# Options: gemini | groq | anthropic | openai | ollama
LLM_PROVIDER=gemini

# Model name must match the provider prefix:
#   gemini   → gemini/gemini-1.5-flash  (free, fast, good quality)
#   gemini   → gemini/gemini-1.5-pro    (free, slower, better for complex tasks)
#   groq     → groq/llama-3.1-70b-versatile  (free, very fast)
#   groq     → groq/mixtral-8x7b-32768       (free)
#   anthropic→ claude-sonnet-4-6
#   openai   → gpt-4o-mini
#   ollama   → ollama/llama3.2  (local, no key needed)
LLM_MODEL=gemini/gemini-1.5-flash

# ── API Keys (only fill the one you're using) ─────────────────────────────────
# Gemini  → get free key at: aistudio.google.com  (Google account, instant)
GEMINI_API_KEY=

# Groq    → get free key at: console.groq.com  (sign up, instant)
GROQ_API_KEY=

# Anthropic → console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI  → platform.openai.com
OPENAI_API_KEY=

# ── Platform credentials ──────────────────────────────────────────────────────
LINKEDIN_EMAIL=inandepu@gmail.com
LINKEDIN_PASSWORD=

NAUKRI_EMAIL=inandepu@gmail.com
NAUKRI_PASSWORD=

WELLFOUND_EMAIL=inandepu@gmail.com
WELLFOUND_PASSWORD=

# ── App settings ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./floww.db
PROFILE_PATH=data/profile/indira_profile.json
LOG_LEVEL=INFO

# ── Job search preferences ────────────────────────────────────────────────────
TARGET_ROLES=Product Manager,Senior Software Engineer,APM,SDE II
MAX_JOBS_PER_PLATFORM=50
ATS_SCORE_THRESHOLD=85
