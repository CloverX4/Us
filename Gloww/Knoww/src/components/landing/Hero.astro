---
const base = import.meta.env.BASE_URL;

const tiles = [
  {
    title: 'About',
    peek: "engineer turned product curious",
    href: `${base}about/`,
    color: '#FF6B6B',
    img: 'https://picsum.photos/seed/about-knoww/700/500',
    area: 'about',
    fade: 0,
  },
  {
    title: 'TIL',
    peek: "things that made me go waaaww",
    href: `${base}til/`,
    color: '#4ECDC4',
    img: 'https://picsum.photos/seed/til-knoww/600/400',
    area: 'til',
    fade: 1,
    bleedOrigin: '100% 100%',  // bottom-right corner
  },
  {
    title: 'Product',
    peek: "teardowns and product thoughts",
    href: `${base}product/`,
    color: '#1A1A2E',
    img: 'https://picsum.photos/seed/product-knoww/600/400',
    area: 'product',
    fade: 0,
  },
  {
    title: 'Builds',
    peek: "Floww & more",
    href: `${base}builds/`,
    color: '#FF6B6B',
    img: 'https://picsum.photos/seed/builds-knoww/700/400',
    area: 'builds',
    fade: 1,
  },
  {
    title: 'Personal',
    peek: "anime, hobbies, vibes",
    href: `${base}personal/`,
    color: '#FFB347',
    img: 'https://picsum.photos/seed/personal-vibes/600/500',
    area: 'personal',
    fade: 1,
    bleedOrigin: '100% 0%',    // top-right corner
  },
  {
    title: "Let's Talk",
    peek: "say hi!!",
    href: `${base}lets-talk/`,
    color: '#F7E8D4',
    img: 'https://picsum.photos/seed/talk-knoww/500/400',
    area: 'talk',
    fade: 0,
  },
];

const tileShadow = '0 2px 8px rgba(0,0,0,0.10), 0 8px 25px rgba(0,0,0,0.12)';
// bleed tiles: color fades to transparent on the right, no hard right edge
const bleedSet = new Set(['til', 'builds', 'personal']);
---

<section class="relative h-screen overflow-hidden">
  <canvas
    id="hero-particles"
    class="pointer-events-none absolute inset-0 z-0 hidden lg:block"
  ></canvas>

  <div
    class="absolute inset-0 z-0 lg:hidden"
    style="background: radial-gradient(ellipse at 30% 40%, color-mix(in srgb, var(--color-coral) 8%, transparent), transparent 60%), radial-gradient(ellipse at 70% 60%, color-mix(in srgb, var(--color-teal) 6%, transparent), transparent 50%);"
  ></div>

  <!-- Desktop: grid left, heading right -->
  <div class="hidden lg:flex w-full h-screen items-center">

    <!-- LEFT: tile grid (extends under heading for bleed tiles) -->
    <div
      class="tile-grid relative z-10"
      style="
        width: 72%;
        height: 80vh;
        padding: 4vh 0 4vh 5%;
        display: grid;
        grid-template-columns: 1fr 1.1fr 0.7fr 0.6fr;
        grid-template-rows: 1fr 1fr 1fr;
        grid-template-areas:
          'about   til      til      til'
          'about   product  builds   .'
          'talk    personal personal personal';
        gap: 10px;
      "
    >
      {tiles.map((tile) => {
        const bleeds = bleedSet.has(tile.area);
        return (
          <a
            href={tile.href}
            class="grid-tile relative overflow-hidden no-underline cursor-pointer"
            style={`
              grid-area: ${tile.area};
              border-radius: ${bleeds ? '6px 0 0 6px' : '6px'};
              box-shadow: ${bleeds ? 'none' : tileShadow};
            `}
            data-color={tile.color}
            data-bleeds={bleeds ? 'true' : 'false'}
          >
            <img
              src={tile.img}
              alt={tile.title}
              class="tile-img absolute inset-0 w-full h-full object-cover"
              style={bleeds
                ? tile.bleedOrigin
                  ? `-webkit-mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%); mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%);`
                  : '-webkit-mask-image: linear-gradient(to right, black 50%, transparent 95%); mask-image: linear-gradient(to right, black 50%, transparent 95%);'
                : ''}
              loading="lazy"
            />

            <div
              class="tile-color absolute inset-0"
              style={bleeds
                ? tile.bleedOrigin
                  ? `background: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, ${tile.color}26 30%, ${tile.color}66 48%, ${tile.color}B3 62%, ${tile.color} 78%);`
                  : `background: linear-gradient(to right, ${tile.color} 50%, transparent 100%);`
                : `background: ${tile.color};`}
            ></div>

            <div class="tile-label absolute inset-0 flex flex-col items-center justify-center text-center p-4"
              style={bleeds ? 'padding-right: 30%;' : ''}
            >
              <span
                class="text-lg lg:text-xl font-bold tracking-wide"
                style={`font-family: var(--font-display); color: ${tile.color === '#1A1A2E' || tile.color === '#FF6B6B' ? 'white' : 'var(--color-navy)'};`}
              >
                {tile.title}
              </span>
            </div>

            <div
              class="tile-info absolute bottom-0 left-0 right-0 px-4 py-4 translate-y-full"
              style={`background: linear-gradient(to top, rgba(0,0,0,0.88), rgba(0,0,0,0.45) 75%, transparent); ${bleeds
                ? tile.bleedOrigin
                  ? `-webkit-mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%); mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%);`
                  : '-webkit-mask-image: linear-gradient(to right, black 50%, transparent 95%); mask-image: linear-gradient(to right, black 50%, transparent 95%);'
                : ''}`}
            >
              <p class="text-sm font-bold text-white leading-tight" style="font-family: var(--font-display);">
                {tile.title}
              </p>
              <p class="text-xs text-white/70 mt-1 leading-snug" style="font-family: var(--font-body);">
                {tile.peek}
              </p>
            </div>
          </a>
        );
      })}
    </div>

    <!-- RIGHT: heading (overlaps bleeding tiles) -->
    <div
      class="absolute z-20 flex flex-col justify-center items-start"
      style="top: 0; bottom: 0; right: 0; width: 40%; padding: 4% 5% 0 3%;"
    >
      <h1
        id="hero-heading"
        class="mb-4 font-bold leading-[0.9] tracking-tight"
        style="font-family: var(--font-display); font-size: clamp(4rem, 7vw, 6.5rem);"
      >
        <span class="hero-word" style="color: var(--color-navy);">Knoww</span>{' '}
        <span class="hero-word" style="background: linear-gradient(135deg, var(--color-coral), var(--color-amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">ME</span>
        <span class="hero-word" style="color: var(--color-navy);">..</span>
        <br />
        <span class="hero-word" style="color: var(--color-teal);">hereee</span>
        <span class="hero-word" style="color: var(--color-coral);">!!</span>
      </h1>

      <p
        id="hero-subtitle"
        class="text-sm tracking-wide"
        style="color: color-mix(in srgb, var(--color-navy) 70%, transparent); font-family: var(--font-body); opacity: 0;"
      >
        engineer. product thinker. anime lover.<br />professionally curious.
      </p>
    </div>
  </div>

  <!-- Mobile -->
  <div class="flex flex-col items-center gap-8 lg:hidden px-4 py-16">
    <div class="text-center">
      <h1
        class="mb-3 text-4xl font-bold leading-tight tracking-tight"
        style="font-family: var(--font-display);"
      >
        <span style="color: var(--color-navy);">Knoww </span>
        <span style="background: linear-gradient(135deg, var(--color-coral), var(--color-amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">ME</span>
        <span style="color: var(--color-navy);">..</span>
        <br />
        <span style="color: var(--color-teal);">hereee</span>
        <span style="color: var(--color-coral);">!!</span>
      </h1>
      <p class="text-sm" style="color: color-mix(in srgb, var(--color-navy) 45%, transparent);">
        engineer. product thinker. anime lover. professionally curious.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-3 w-full max-w-sm">
      {tiles.map((tile) => (
        <a
          href={tile.href}
          class="relative flex flex-col items-center justify-center gap-2 overflow-hidden p-5 no-underline transition-transform duration-300 active:scale-95"
          style={`background: ${tile.color}; border-radius: 6px; min-height: 90px;`}
        >
          <span
            class="text-xs font-bold"
            style={`font-family: var(--font-display); color: ${tile.color === '#1A1A2E' || tile.color === '#FF6B6B' ? 'white' : 'var(--color-navy)'};`}
          >
            {tile.title}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  if (window.innerWidth >= 1024) {
    // Heading animation
    const words = document.querySelectorAll('.hero-word');
    gsap.set(words, { opacity: 0, y: 40 });
    gsap.to(words, {
      opacity: 1, y: 0,
      duration: 0.7, stagger: 0.1,
      ease: 'power3.out', delay: 0.8,
    });

    const subtitle = document.getElementById('hero-subtitle');
    if (subtitle) gsap.to(subtitle, { opacity: 1, duration: 0.6, delay: 1.6 });

    // Tile animations
    const hoverShadow = '0 6px 12px rgba(0,0,0,0.12), 0 20px 50px rgba(0,0,0,0.2), 0 40px 80px rgba(0,0,0,0.1)';

    const tiles = document.querySelectorAll('.grid-tile');
    tiles.forEach((tile, i) => {
      // Staggered entrance
      gsap.fromTo(tile, {
        opacity: 0,
        y: 30,
      }, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        delay: 0.2 + i * 0.1,
        ease: 'power3.out',
      });

      const colorOverlay = tile.querySelector('.tile-color') as HTMLElement;
      const label = tile.querySelector('.tile-label') as HTMLElement;
      const info = tile.querySelector('.tile-info') as HTMLElement;
      const baseShadow = getComputedStyle(tile).boxShadow;

      tile.addEventListener('mouseenter', () => {
        gsap.to(tile, {
          scale: 1.03, zIndex: 50, duration: 0.4,
          ease: 'power2.out',
          boxShadow: hoverShadow,
          overwrite: true,
        });
        gsap.to(colorOverlay, { opacity: 0, duration: 0.8, ease: 'power1.out', overwrite: true });
        gsap.to(label, { opacity: 0, y: -8, duration: 0.25, overwrite: true });
        gsap.to(info, { y: 0, duration: 0.45, delay: 0.2, ease: 'power2.out', overwrite: true });
      });

      tile.addEventListener('mouseleave', () => {
        gsap.killTweensOf(colorOverlay);
        gsap.killTweensOf(label);
        gsap.killTweensOf(info);
        gsap.to(tile, {
          scale: 1, zIndex: 'auto', duration: 0.35,
          ease: 'power2.out',
          boxShadow: baseShadow,
          overwrite: true,
        });
        gsap.to(colorOverlay, { opacity: 1, duration: 0.35, ease: 'power2.in' });
        gsap.to(label, { opacity: 1, y: 0, duration: 0.25 });
        gsap.to(info, { y: '100%', duration: 0.25, ease: 'power2.in' });
      });
    });

    // Particles
    import('three').then(({ Scene, PerspectiveCamera, WebGLRenderer, BufferGeometry, Float32BufferAttribute, PointsMaterial, Points, Color }) => {
      const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
      if (!canvas) return;

      const scene = new Scene();
      const camera = new PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
      camera.position.z = 5;

      const renderer = new WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setSize(window.innerWidth, window.innerHeight);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const count = 60;
      const positions = new Float32Array(count * 3);
      const colors = new Float32Array(count * 3);
      const palette = [new Color('#FF6B6B'), new Color('#FFB347'), new Color('#4ECDC4'), new Color('#F7E8D4')];

      for (let i = 0; i < count; i++) {
        positions[i * 3] = (Math.random() - 0.5) * 14;
        positions[i * 3 + 1] = (Math.random() - 0.5) * 10;
        positions[i * 3 + 2] = (Math.random() - 0.5) * 6;
        const c = palette[Math.floor(Math.random() * palette.length)];
        colors[i * 3] = c.r; colors[i * 3 + 1] = c.g; colors[i * 3 + 2] = c.b;
      }

      const geo = new BufferGeometry();
      geo.setAttribute('position', new Float32BufferAttribute(positions, 3));
      geo.setAttribute('color', new Float32BufferAttribute(colors, 3));
      const mat = new PointsMaterial({ size: 0.04, vertexColors: true, transparent: true, opacity: 0.25 });
      const points = new Points(geo, mat);
      scene.add(points);

      gsap.fromTo(canvas, { opacity: 0 }, { opacity: 1, duration: 2, delay: 0.5 });

      let time = 0;
      function animate() {
        time += 0.002;
        const pos = geo.attributes.position.array as Float32Array;
        for (let i = 0; i < count; i++) {
          pos[i * 3 + 1] += Math.sin(time + i * 0.1) * 0.001;
          pos[i * 3] += Math.cos(time + i * 0.05) * 0.0008;
        }
        geo.attributes.position.needsUpdate = true;
        points.rotation.y = time * 0.08;
        renderer.render(scene, camera);
        requestAnimationFrame(animate);
      }
      animate();

      window.addEventListener('resize', () => {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    });
  }
</script>
