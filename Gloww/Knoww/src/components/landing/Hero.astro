---
const base = import.meta.env.BASE_URL;

const tiles = [
  {
    title: 'About',
    peek: "engineer turned product curious",
    href: `${base}about/`,
    color: '#FF6B6B',
    img: 'https://picsum.photos/seed/about-knoww/700/500',
    area: 'about',
    fade: 0,
  },
  {
    title: 'TIL',
    peek: "things that made me go waaaww",
    href: `${base}til/`,
    color: '#4ECDC4',
    img: 'https://picsum.photos/seed/til-knoww/600/400',
    area: 'til',
    fade: 1,
    bleedOrigin: '100% 100%',  // bottom-right corner
  },
  {
    title: 'Product',
    peek: "teardowns and product thoughts",
    href: `${base}product/`,
    color: '#FFB347',
    img: 'https://picsum.photos/seed/product-knoww/600/400',
    area: 'product',
    fade: 0,
  },
  {
    title: 'Builds',
    peek: "Floww & more",
    href: `${base}builds/`,
    color: '#FF6B6B',
    img: 'https://picsum.photos/seed/builds-knoww/700/400',
    area: 'builds',
    fade: 1,
  },
  {
    title: 'Personal',
    peek: "anime, hobbies, vibes",
    href: `${base}personal/`,
    color: '#1A1A2E',
    img: 'https://picsum.photos/seed/personal-vibes/600/500',
    area: 'personal',
    fade: 1,
    bleedOrigin: '100% 0%',    // top-right corner
  },
  {
    title: "Let's Talk",
    peek: "say hi!!",
    href: `${base}lets-talk/`,
    color: '#F7E8D4',
    img: 'https://picsum.photos/seed/talk-knoww/500/400',
    area: 'talk',
    fade: 0,
  },
];

const tileShadow = '0 2px 6px rgba(0,0,0,0.06), 0 8px 25px rgba(0,0,0,0.10), 0 20px 50px rgba(0,0,0,0.08), 0 0 40px rgba(255,255,255,0.5)';
// bleed tiles: color fades to transparent on the right, no hard right edge
const bleedSet = new Set(['til', 'builds', 'personal']);
---

<section class="relative h-screen overflow-hidden">
  <!-- Layer 1: Solid particles moving in background -->
  <div id="particle-bg" class="pointer-events-none absolute inset-0 hidden lg:block" style="z-index: 1;"></div>
  <div id="particle-bg-mobile" class="pointer-events-none absolute inset-0 lg:hidden" style="z-index: 1;"></div>

  <!-- Layer 2: Light frosted overlay — softens particles underneath -->
  <div class="pointer-events-none absolute inset-0 hidden lg:block" style="z-index: 2; background: rgba(255,248,240,0.18); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);"></div>
  <div class="pointer-events-none absolute inset-0 lg:hidden" style="z-index: 2; background: rgba(255,248,240,0.12); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);"></div>

  <!-- Desktop: grid left, heading right -->
  <div class="hidden lg:flex w-full h-screen items-center">

    <!-- LEFT: tile grid (extends under heading for bleed tiles) -->
    <div
      class="tile-grid"
      id="tile-grid"
      style="
        position: relative;
        z-index: 10;
        width: 70%;
        height: 82vh;
        padding: 4vh 0 4vh 5%;
        display: grid;
        grid-template-columns: 1fr 1.1fr 0.7fr 0.6fr;
        grid-template-rows: 1fr 1fr 1fr;
        grid-template-areas:
          'about   til      til      til'
          'about   product  builds   .'
          'talk    personal personal personal';
        gap: 10px;
      "
    >
      {tiles.map((tile) => {
        const bleeds = bleedSet.has(tile.area);
        return (
          <a
            href={tile.href}
            class="grid-tile relative overflow-hidden no-underline cursor-pointer"
            style={`
              grid-area: ${tile.area};
              border-radius: ${bleeds ? '6px 0 0 6px' : '6px'};
              box-shadow: ${bleeds ? 'none' : tileShadow};
            `}
            data-color={tile.color}
            data-bleeds={bleeds ? 'true' : 'false'}
          >
            <img
              src={tile.img}
              alt={tile.title}
              class="tile-img absolute inset-0 w-full h-full object-cover"
              style={bleeds
                ? tile.bleedOrigin
                  ? `-webkit-mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%); mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%);`
                  : '-webkit-mask-image: linear-gradient(to right, black 50%, transparent 95%); mask-image: linear-gradient(to right, black 50%, transparent 95%);'
                : ''}
              loading="lazy"
            />

            <div
              class="tile-color absolute inset-0"
              style={bleeds
                ? tile.bleedOrigin
                  ? `background: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, ${tile.color}26 30%, ${tile.color}66 48%, ${tile.color}B3 62%, ${tile.color} 78%);`
                  : `background: linear-gradient(to right, ${tile.color} 50%, transparent 100%);`
                : `background: ${tile.color};`}
            ></div>

            <div class="tile-label absolute inset-0 flex flex-col items-center justify-center text-center p-4"
              style={bleeds ? 'padding-right: 30%;' : ''}
            >
              <span
                class="text-lg lg:text-xl font-bold tracking-wide"
                style={`font-family: var(--font-display); color: ${tile.color === '#1A1A2E' || tile.color === '#FF6B6B' ? 'white' : 'var(--color-navy)'};`}
              >
                {tile.title}
              </span>
            </div>

            <div
              class="tile-info absolute bottom-0 left-0 right-0 px-4 py-4 translate-y-full"
              style={`background: linear-gradient(to top, rgba(0,0,0,0.88), rgba(0,0,0,0.45) 75%, transparent); ${bleeds
                ? tile.bleedOrigin
                  ? `-webkit-mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%); mask-image: radial-gradient(ellipse 55% 280% at ${tile.bleedOrigin}, transparent 15%, rgba(0,0,0,0.15) 30%, rgba(0,0,0,0.4) 48%, rgba(0,0,0,0.7) 62%, black 78%);`
                  : '-webkit-mask-image: linear-gradient(to right, black 50%, transparent 95%); mask-image: linear-gradient(to right, black 50%, transparent 95%);'
                : ''}`}
            >
              <p class="text-sm font-bold text-white leading-tight" style="font-family: var(--font-display);">
                {tile.title}
              </p>
              <p class="text-xs text-white/70 mt-1 leading-snug" style="font-family: var(--font-body);">
                {tile.peek}
              </p>
            </div>
          </a>
        );
      })}
    </div>

    <!-- RIGHT: heading (overlaps bleeding tiles) -->
    <div
      class="absolute z-20 flex flex-col justify-center items-start"
      style="top: 0; bottom: 0; right: 0; width: 40%; padding: 4% 5% 0 3%;"
    >
      <h1
        id="hero-heading"
        class="mb-4 font-bold leading-[0.9] tracking-tight"
        style="font-family: var(--font-display); font-size: clamp(4rem, 7vw, 6.5rem);"
      >
        <span class="hero-word" style="color: var(--color-navy);">Knoww</span>{' '}
        <span class="hero-word" style="background: linear-gradient(135deg, var(--color-coral), var(--color-amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">ME</span>
        <span class="hero-word" style="color: var(--color-navy);">..</span>
        <br />
        <span class="hero-word" style="color: var(--color-teal);">hereee</span>
        <span class="hero-word" style="color: var(--color-coral);">!!</span>
      </h1>

      <p
        id="hero-subtitle"
        class="text-sm tracking-wide"
        style="color: color-mix(in srgb, var(--color-navy) 70%, transparent); font-family: var(--font-body); font-size: 0.9rem; opacity: 0;"
      >
        engineer. product thinker. anime lover.<br />professionally curious.
      </p>
    </div>
  </div>

  <!-- Mobile -->
  <div class="relative flex flex-col items-center gap-6 lg:hidden px-4 pt-14 pb-8" style="z-index: 10;">
    <div class="text-center">
      <h1
        class="mb-3 text-4xl font-bold leading-tight tracking-tight"
        style="font-family: var(--font-display);"
      >
        <span style="color: var(--color-navy);">Knoww </span>
        <span style="background: linear-gradient(135deg, var(--color-coral), var(--color-amber)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">ME</span>
        <span style="color: var(--color-navy);">..</span>
        <br />
        <span style="color: var(--color-teal);">hereee</span>
        <span style="color: var(--color-coral);">!!</span>
      </h1>
      <p class="text-sm" style="color: color-mix(in srgb, var(--color-navy) 45%, transparent);">
        engineer. product thinker. anime lover. professionally curious.
      </p>
    </div>

    <div
      class="mobile-bento w-full"
      style="
        max-width: 400px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
        grid-template-areas:
          'about   til'
          'about   product'
          'personal personal'
          'talk    builds';
        gap: 10px;
      "
    >
      {tiles.map((tile) => (
        <a
          href={tile.href}
          class="mobile-tile relative overflow-hidden no-underline cursor-pointer"
          style={`grid-area: ${tile.area}; border-radius: 14px; min-height: ${tile.area === 'about' ? '180px' : tile.area === 'personal' ? '100px' : '85px'};`}
          data-color={tile.color}
        >
          <img
            src={tile.img}
            alt={tile.title}
            class="mobile-tile-img absolute inset-0 w-full h-full object-cover"
            loading="lazy"
          />

          <div
            class="mobile-tile-color absolute inset-0"
            style={`background: ${tile.color};`}
          ></div>

          <div class="mobile-tile-label absolute inset-0 flex flex-col items-center justify-center text-center p-3">
            <span
              class="text-sm font-bold tracking-wide"
              style={`font-family: var(--font-display); color: ${tile.color === '#1A1A2E' || tile.color === '#FF6B6B' ? 'white' : 'var(--color-navy)'};`}
            >
              {tile.title}
            </span>
            <span
              class="text-[10px] mt-0.5 opacity-60"
              style={`font-family: var(--font-body); color: ${tile.color === '#1A1A2E' || tile.color === '#FF6B6B' ? 'white' : 'var(--color-navy)'};`}
            >
              {tile.peek}
            </span>
          </div>

          <div
            class="mobile-tile-info absolute bottom-0 left-0 right-0 px-3 py-3 translate-y-full"
            style="background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0.4) 70%, transparent);"
          >
            <p class="text-xs font-bold text-white leading-tight" style="font-family: var(--font-display);">
              {tile.title}
            </p>
            <p class="text-[10px] text-white/70 mt-0.5 leading-snug" style="font-family: var(--font-body);">
              {tile.peek}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .grid-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 1px 2px rgba(255,255,255,0.5), inset 0 -1px 2px rgba(0,0,0,0.08);
    border-top: 1px solid rgba(255,255,255,0.3);
    pointer-events: none;
    z-index: 5;
  }

  /* Mobile tile glass edge */
  .mobile-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 1px 2px rgba(255,255,255,0.4), inset 0 -1px 2px rgba(0,0,0,0.06);
    border-top: 1px solid rgba(255,255,255,0.25);
    pointer-events: none;
    z-index: 5;
  }

  .mobile-tile {
    box-shadow: 0 2px 8px rgba(0,0,0,0.08), 0 8px 20px rgba(0,0,0,0.06);
    transition: transform 0.3s ease;
  }

  .mobile-tile:active {
    transform: scale(0.97);
  }
</style>

<script>
  import { gsap } from 'gsap';

  if (window.innerWidth >= 1024) {
    // Heading animation
    const words = document.querySelectorAll('.hero-word');
    gsap.set(words, { opacity: 0, y: 40 });
    gsap.to(words, {
      opacity: 1, y: 0,
      duration: 0.7, stagger: 0.1,
      ease: 'power3.out', delay: 0.8,
    });

    const subtitle = document.getElementById('hero-subtitle');
    if (subtitle) gsap.to(subtitle, { opacity: 1, duration: 0.6, delay: 1.6 });

    // ── Solid particles (behind frosted overlay) ──
    const particleBg = document.getElementById('particle-bg');
    if (particleBg) {
      const particleColors = [
        '#FF6B6B',  // coral
        '#FFB347',  // amber
        '#4ECDC4',  // teal
        '#F7E8D4',  // peach
        '#FF8A80',  // light coral
        '#80CBC4',  // light teal
      ];
      const particleCount = 24;
      const particles: HTMLElement[] = [];

      // Spread evenly using a grid-ish distribution
      for (let i = 0; i < particleCount; i++) {
        const dot = document.createElement('div');
        const size = 25 + Math.random() * 55;
        // Grid-based placement with jitter — ensures even spread
        const cols = 6, rows = 4;
        const col = i % cols;
        const row = Math.floor(i / cols);
        const x = (col / cols) * 100 + (Math.random() - 0.5) * (100 / cols);
        const y = (row / rows) * 100 + (Math.random() - 0.5) * (100 / rows);
        const color = particleColors[Math.floor(Math.random() * particleColors.length)];

        dot.style.cssText = `
          position: absolute;
          width: ${size}px;
          height: ${size}px;
          left: ${x}%;
          top: ${y}%;
          border-radius: 50%;
          background: ${color};
          opacity: 0;
          will-change: transform;
        `;
        dot.classList.add('bg-particle');
        particleBg.appendChild(dot);
        particles.push(dot);

        // Fade in
        gsap.to(dot, {
          opacity: 0.5 + Math.random() * 0.35,
          duration: 1.5,
          delay: 0.2 + i * 0.06,
          ease: 'power1.out',
        });

        // Movement — oscillate around starting position, not drifting away
        const speed = 2.5 + Math.random() * 2;
        const rangeX = 40 + Math.random() * 80;
        const rangeY = 30 + Math.random() * 60;
        // Alternate direction so they don't all drift the same way
        const dirX = i % 2 === 0 ? 1 : -1;
        const dirY = i % 3 === 0 ? 1 : -1;
        gsap.to(dot, {
          x: dirX * rangeX,
          y: dirY * rangeY,
          duration: speed,
          ease: 'sine.inOut',
          repeat: -1,
          yoyo: true,
          delay: Math.random() * 1.5,
        });
      }
    }

    // ── Mouse parallax ──
    const tileGrid = document.getElementById('tile-grid');
    let mouseX = 0.5, mouseY = 0.5;
    let currentX = 0.5, currentY = 0.5;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX / window.innerWidth;
      mouseY = e.clientY / window.innerHeight;
    });

    function parallaxLoop() {
      currentX += (mouseX - currentX) * 0.04;
      currentY += (mouseY - currentY) * 0.04;

      const offsetX = (currentX - 0.5) * -28;
      const offsetY = (currentY - 0.5) * -18;

      if (tileGrid) {
        tileGrid.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
      }

      requestAnimationFrame(parallaxLoop);
    }
    parallaxLoop();

    // ── Tile animations ──
    const hoverShadow = '0 8px 16px rgba(0,0,0,0.12), 0 24px 60px rgba(0,0,0,0.18), 0 50px 100px rgba(0,0,0,0.08)';

    const tiles = document.querySelectorAll('.grid-tile');
    tiles.forEach((tile, i) => {
      const floatY = 3 + Math.random() * 4;
      const floatDuration = 6 + Math.random() * 3;

      // Staggered entrance, then float
      gsap.fromTo(tile, {
        opacity: 0,
        y: 30,
      }, {
        opacity: 1,
        y: 0,
        duration: 0.7,
        delay: 0.2 + i * 0.1,
        ease: 'power3.out',
        onComplete: () => {
          gsap.to(tile, {
            y: floatY,
            duration: floatDuration,
            ease: 'sine.inOut',
            repeat: -1,
            yoyo: true,
          });
        },
      });

      const colorOverlay = tile.querySelector('.tile-color') as HTMLElement;
      const label = tile.querySelector('.tile-label') as HTMLElement;
      const info = tile.querySelector('.tile-info') as HTMLElement;
      const baseShadow = getComputedStyle(tile).boxShadow;

      tile.addEventListener('mouseenter', () => {
        gsap.to(tile, {
          scale: 1.03, zIndex: 50, duration: 0.4,
          ease: 'power2.out',
          boxShadow: hoverShadow,
          overwrite: true,
        });
        gsap.to(colorOverlay, { opacity: 0, duration: 0.8, ease: 'power1.out', overwrite: true });
        gsap.to(label, { opacity: 0, y: -8, duration: 0.25, overwrite: true });
        gsap.to(info, { y: 0, duration: 0.45, delay: 0.2, ease: 'power2.out', overwrite: true });
      });

      tile.addEventListener('mouseleave', () => {
        gsap.killTweensOf(colorOverlay);
        gsap.killTweensOf(label);
        gsap.killTweensOf(info);
        gsap.to(tile, {
          scale: 1, zIndex: 'auto', duration: 0.35,
          ease: 'power2.out',
          boxShadow: baseShadow,
          overwrite: true,
        });
        gsap.to(colorOverlay, { opacity: 1, duration: 0.35, ease: 'power2.in' });
        gsap.to(label, { opacity: 1, y: 0, duration: 0.25 });
        gsap.to(info, { y: '100%', duration: 0.25, ease: 'power2.in' });
      });
    });
  }

  // ── Mobile particles (smaller, fewer, faster) ──
  if (window.innerWidth < 1024) {
    const mobileBg = document.getElementById('particle-bg-mobile');
    if (mobileBg) {
      const colors = ['#FF6B6B','#FFB347','#4ECDC4','#F7E8D4','#FF8A80','#80CBC4'];
      const count = 20;
      for (let i = 0; i < count; i++) {
        const dot = document.createElement('div');
        const size = 14 + Math.random() * 35;
        const cols = 5, rows = 4;
        const col = i % cols;
        const row = Math.floor(i / cols);
        const x = (col / cols) * 100 + (Math.random() - 0.5) * (100 / cols);
        const y = (row / rows) * 100 + (Math.random() - 0.5) * (100 / rows);
        dot.style.cssText = `
          position: absolute;
          width: ${size}px; height: ${size}px;
          left: ${x}%; top: ${y}%;
          border-radius: 50%;
          background: ${colors[Math.floor(Math.random() * colors.length)]};
          opacity: 0; will-change: transform;
        `;
        mobileBg.appendChild(dot);
        gsap.to(dot, { opacity: 0.35 + Math.random() * 0.25, duration: 1, delay: 0.1 + i * 0.05, ease: 'power1.out' });
        const speed = 1.8 + Math.random() * 1.5;
        const rx = 25 + Math.random() * 50;
        const ry = 20 + Math.random() * 40;
        gsap.to(dot, {
          x: (i % 2 === 0 ? 1 : -1) * rx,
          y: (i % 3 === 0 ? 1 : -1) * ry,
          duration: speed, ease: 'sine.inOut', repeat: -1, yoyo: true, delay: Math.random(),
        });
      }
    }
  }

  // ── Mobile: tap to reveal image, tap again to navigate ──
  if (window.innerWidth < 1024) {
    const mobileTiles = document.querySelectorAll('.mobile-tile');
    let activeTile: Element | null = null;

    mobileTiles.forEach((tile) => {
      const colorOverlay = tile.querySelector('.mobile-tile-color') as HTMLElement;
      const label = tile.querySelector('.mobile-tile-label') as HTMLElement;
      const info = tile.querySelector('.mobile-tile-info') as HTMLElement;

      tile.addEventListener('click', (e) => {
        if (activeTile === tile) {
          // Second tap — navigate (default link behavior)
          return;
        }

        e.preventDefault();

        // Close any previously active tile
        if (activeTile && activeTile !== tile) {
          const prevColor = activeTile.querySelector('.mobile-tile-color') as HTMLElement;
          const prevLabel = activeTile.querySelector('.mobile-tile-label') as HTMLElement;
          const prevInfo = activeTile.querySelector('.mobile-tile-info') as HTMLElement;
          gsap.to(prevColor, { opacity: 1, duration: 0.3 });
          gsap.to(prevLabel, { opacity: 1, y: 0, duration: 0.2 });
          gsap.to(prevInfo, { y: '100%', duration: 0.2 });
        }

        // Reveal this tile
        activeTile = tile;
        gsap.to(colorOverlay, { opacity: 0, duration: 0.5, ease: 'power1.out' });
        gsap.to(label, { opacity: 0, y: -6, duration: 0.2 });
        gsap.to(info, { y: 0, duration: 0.35, delay: 0.1, ease: 'power2.out' });
      });
    });

    // Tap outside closes active tile
    document.addEventListener('click', (e) => {
      if (activeTile && !(e.target as Element).closest('.mobile-tile')) {
        const prevColor = activeTile.querySelector('.mobile-tile-color') as HTMLElement;
        const prevLabel = activeTile.querySelector('.mobile-tile-label') as HTMLElement;
        const prevInfo = activeTile.querySelector('.mobile-tile-info') as HTMLElement;
        gsap.to(prevColor, { opacity: 1, duration: 0.3 });
        gsap.to(prevLabel, { opacity: 1, y: 0, duration: 0.2 });
        gsap.to(prevInfo, { y: '100%', duration: 0.2 });
        activeTile = null;
      }
    });

    // Staggered entrance for mobile tiles
    mobileTiles.forEach((tile, i) => {
      gsap.fromTo(tile,
        { opacity: 0, y: 20 },
        { opacity: 1, y: 0, duration: 0.5, delay: 0.3 + i * 0.08, ease: 'power2.out' }
      );
    });
  }
</script>
