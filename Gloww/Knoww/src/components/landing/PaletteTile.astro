---
interface Props {
  title: string;
  subtitle: string;
  href: string;
  color: string;
  gradientDir?: string;
  icon: string;
  peek: string;
  gridArea: string;
}

const { title, subtitle, href, color, gradientDir = 'to bottom right', icon, peek, gridArea } = Astro.props;
---

<a
  href={href}
  class="palette-tile group relative flex flex-col justify-end overflow-hidden rounded-3xl p-6 no-underline transition-all duration-300 sm:p-8"
  style={`grid-area: ${gridArea}; background: linear-gradient(${gradientDir}, ${color}, color-mix(in srgb, ${color} 40%, var(--color-cream)));`}
  data-color={color}
>
  <!-- Icon -->
  <span class="mb-2 text-3xl sm:text-4xl">{icon}</span>

  <!-- Title -->
  <h2
    class="text-xl font-bold sm:text-2xl"
    style="font-family: var(--font-display); color: var(--color-navy);"
  >
    {title}
  </h2>

  <!-- Subtitle -->
  <p
    class="mt-1 text-sm"
    style="color: color-mix(in srgb, var(--color-navy) 55%, transparent); font-family: var(--font-body);"
  >
    {subtitle}
  </p>

  <!-- Peek content (slides up on hover) -->
  <div
    class="peek absolute bottom-0 left-0 right-0 translate-y-full rounded-b-3xl px-6 py-4 opacity-0 transition-all duration-300 sm:px-8"
    style="background: linear-gradient(to top, color-mix(in srgb, var(--color-navy) 85%, transparent), transparent); backdrop-filter: blur(8px);"
  >
    <p class="text-sm text-white/80" style="font-family: var(--font-body);">
      {peek}
    </p>
  </div>

  <!-- Hover glow overlay -->
  <div
    class="pointer-events-none absolute inset-0 rounded-3xl opacity-0 transition-opacity duration-300"
    style={`box-shadow: inset 0 0 60px color-mix(in srgb, ${color} 20%, transparent);`}
  ></div>
</a>
