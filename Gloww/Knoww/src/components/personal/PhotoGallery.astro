---
interface Props {
  photos: { src: string; caption?: string }[];
}

const { photos } = Astro.props;
---

{photos.length > 0 && (
  <section>
    <h2 class="text-2xl font-bold mb-6" style="font-family: var(--font-display); color: var(--color-navy);">
      through my lens 📸
    </h2>
    <p class="text-sm mb-8" style="color: color-mix(in srgb, var(--color-navy) 50%, transparent);">
      my phone storage has been crying ever since college. here's some of what i've captured:
    </p>

    <!-- Infinite ribbon -->
    <div class="ribbon-wrap overflow-hidden -mx-6 sm:-mx-8" style="mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);">
      <!-- Row 1: scrolls left -->
      <div class="ribbon-row ribbon-left flex gap-3 mb-3" data-direction="left">
        {[...photos, ...photos].map((photo, i) => (
          <div
            class="ribbon-photo shrink-0 rounded-xl overflow-hidden cursor-pointer"
            style="height: 180px;"
            data-index={i % photos.length}
          >
            <img
              src={photo.src}
              alt={photo.caption || 'photo'}
              class="h-full w-auto object-cover transition-transform duration-300 hover:scale-105"
              loading="lazy"
              style="min-width: 120px; max-width: 320px;"
            />
          </div>
        ))}
      </div>

      <!-- Row 2: scrolls right -->
      <div class="ribbon-row ribbon-right flex gap-3" data-direction="right">
        {[...photos.slice().reverse(), ...photos.slice().reverse()].map((photo, i) => {
          const realIndex = photos.length - 1 - (i % photos.length);
          return (
            <div
              class="ribbon-photo shrink-0 rounded-xl overflow-hidden cursor-pointer"
              style="height: 160px;"
              data-index={realIndex}
            >
              <img
                src={photo.src}
                alt={photo.caption || 'photo'}
                class="h-full w-auto object-cover transition-transform duration-300 hover:scale-105"
                loading="lazy"
                style="min-width: 100px; max-width: 280px;"
              />
            </div>
          );
        })}
      </div>
    </div>

    <!-- Lightbox: card deck viewer -->
    <div id="photo-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center" style="background: rgba(26,26,46,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);">
      <!-- Close button -->
      <button id="lb-close" class="absolute top-5 right-5 z-50 w-10 h-10 flex items-center justify-center rounded-full text-white/60 hover:text-white transition-colors" style="background: rgba(255,255,255,0.1);">
        ✕
      </button>

      <!-- Nav arrows -->
      <button id="lb-prev" class="absolute left-3 sm:left-6 z-50 w-10 h-10 flex items-center justify-center rounded-full text-white/60 hover:text-white text-xl transition-colors" style="background: rgba(255,255,255,0.08); top: 50%; transform: translateY(-50%);">
        ‹
      </button>
      <button id="lb-next" class="absolute right-3 sm:right-6 z-50 w-10 h-10 flex items-center justify-center rounded-full text-white/60 hover:text-white text-xl transition-colors" style="background: rgba(255,255,255,0.08); top: 50%; transform: translateY(-50%);">
        ›
      </button>

      <!-- Card deck container — centered, ~60% screen -->
      <div id="lb-deck" class="relative" style="width: 60vw; max-width: 600px; height: 65vh; max-height: 500px;">
        <!-- Cards rendered by JS -->
      </div>

      <!-- Caption -->
      <p id="lb-caption" class="absolute text-sm text-white/70 text-center" style="font-family: var(--font-body); bottom: 4vh; left: 50%; transform: translateX(-50%); min-height: 1.5em;"></p>
    </div>
  </section>
)}

<style>
  .ribbon-row {
    will-change: transform;
  }

  .ribbon-photo {
    transition: box-shadow 0.3s;
  }

  .ribbon-photo:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }

  #photo-lightbox.active {
    display: flex;
  }

  .deck-card {
    position: absolute;
    top: 0;
    left: 0;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }

  .deck-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .deck-card.center {
    z-index: 10;
    box-shadow: 0 8px 40px rgba(0,0,0,0.45);
    cursor: default;
  }
</style>

<script>
  import { gsap } from 'gsap';

  // ── Ribbon auto-scroll ──
  const rows = document.querySelectorAll('.ribbon-row');
  const ribbonAnims: gsap.core.Tween[] = [];

  rows.forEach((row) => {
    const dir = row.getAttribute('data-direction');
    const scrollWidth = row.scrollWidth / 2;

    if (dir === 'right') {
      gsap.set(row, { x: -scrollWidth });
    }

    const anim = gsap.to(row, {
      x: dir === 'left' ? -scrollWidth : 0,
      duration: dir === 'left' ? 40 : 45,
      ease: 'none',
      repeat: -1,
    });

    ribbonAnims.push(anim);
  });

  const ribbonWrap = document.querySelector('.ribbon-wrap');
  if (ribbonWrap) {
    ribbonWrap.addEventListener('mouseenter', () => ribbonAnims.forEach(a => a.timeScale(0.2)));
    ribbonWrap.addEventListener('mouseleave', () => ribbonAnims.forEach(a => a.timeScale(1)));
  }

  // ── Lightbox: Card Deck ──
  const lightbox = document.getElementById('photo-lightbox')!;
  const lbDeck = document.getElementById('lb-deck')!;
  const lbCaption = document.getElementById('lb-caption')!;
  const lbClose = document.getElementById('lb-close')!;
  const lbPrev = document.getElementById('lb-prev')!;
  const lbNext = document.getElementById('lb-next')!;

  // Collect unique photos
  const photoEls = document.querySelectorAll('.ribbon-photo');
  const photoMap = new Map<number, { src: string; caption: string }>();
  photoEls.forEach((el) => {
    const idx = parseInt(el.getAttribute('data-index') || '0');
    if (!photoMap.has(idx)) {
      const img = el.querySelector('img')!;
      photoMap.set(idx, { src: img.src, caption: img.alt === 'photo' ? '' : img.alt });
    }
  });

  const photos = Array.from(photoMap.entries()).sort((a, b) => a[0] - b[0]).map(e => e[1]);
  let currentIdx = 0;
  const deckCards: HTMLElement[] = [];

  // How many cards visible beneath on each side
  function sideCount() {
    return window.innerWidth >= 640 ? 4 : 2;
  }

  function buildDeck() {
    lbDeck.innerHTML = '';
    deckCards.length = 0;

    const total = sideCount() * 2 + 1;
    for (let i = 0; i < total; i++) {
      const card = document.createElement('div');
      card.className = 'deck-card';
      const img = document.createElement('img');
      img.loading = 'lazy';
      card.appendChild(img);
      lbDeck.appendChild(card);
      deckCards.push(card);

      card.addEventListener('click', () => {
        const offset = i - sideCount();
        if (offset !== 0) {
          showPhoto(currentIdx + offset);
        }
      });
    }
  }

  function layoutDeck(animate = true) {
    const sides = sideCount();

    // All cards same size — fill the deck container
    const deckRect = lbDeck.getBoundingClientRect();
    const cardW = deckRect.width;
    const cardH = deckRect.height;

    // Displacement per card: slight peek on left/right edges
    const peekX = 10;  // px offset per step
    const peekY = 6;   // px offset per step downward

    deckCards.forEach((card, i) => {
      const offset = i - sides; // e.g. -4..0..4
      const idx = ((currentIdx + offset) % photos.length + photos.length) % photos.length;
      const photo = photos[idx];
      const img = card.querySelector('img')!;

      img.src = photo.src;
      img.alt = photo.caption || '';

      const isCenter = offset === 0;
      const absOffset = Math.abs(offset);

      // Stack: center card on top, cards behind offset slightly
      // Left cards peek to the left, right cards peek to the right
      const x = offset * peekX;
      const y = absOffset * peekY;

      // Z-index: center = highest, further = lower
      const z = 10 - absOffset;

      // Opacity: center fully visible, behind cards slightly dimmed
      const opacity = isCenter ? 1 : Math.max(0.35, 1 - absOffset * 0.14);

      if (isCenter) {
        card.classList.add('center');
      } else {
        card.classList.remove('center');
      }

      gsap.to(card, {
        width: cardW,
        height: cardH,
        x: x,
        y: y,
        opacity,
        zIndex: z,
        duration: animate ? 0.4 : 0,
        ease: 'power2.out',
      });
    });

    lbCaption.textContent = photos[currentIdx]?.caption || '';
  }

  function showPhoto(idx: number) {
    currentIdx = ((idx % photos.length) + photos.length) % photos.length;
    layoutDeck(true);
  }

  function openLightbox(idx: number) {
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
    currentIdx = idx;

    buildDeck();
    layoutDeck(false);

    gsap.fromTo(lightbox, { opacity: 0 }, { opacity: 1, duration: 0.3 });
  }

  function closeLightbox() {
    gsap.to(lightbox, {
      opacity: 0,
      duration: 0.25,
      onComplete: () => {
        lightbox.classList.remove('active');
        document.body.style.overflow = '';
      },
    });
  }

  // Click ribbon photos to open
  photoEls.forEach((el) => {
    el.addEventListener('click', () => {
      const idx = parseInt(el.getAttribute('data-index') || '0');
      openLightbox(idx);
    });
  });

  lbClose.addEventListener('click', closeLightbox);
  lbPrev.addEventListener('click', () => showPhoto(currentIdx - 1));
  lbNext.addEventListener('click', () => showPhoto(currentIdx + 1));

  // Click backdrop to close (only the dark area)
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showPhoto(currentIdx - 1);
    if (e.key === 'ArrowRight') showPhoto(currentIdx + 1);
  });

  // Handle resize
  window.addEventListener('resize', () => {
    if (lightbox.classList.contains('active')) {
      buildDeck();
      layoutDeck(false);
    }
  });
</script>
