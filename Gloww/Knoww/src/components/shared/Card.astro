---
interface Props {
  title: string;
  description: string;
  href: string;
  date?: Date;
  tags?: string[];
  emoji?: string;
  accentColor?: string;
}

const { title, description, href, date, tags = [], emoji, accentColor = 'var(--color-coral)' } = Astro.props;

const formattedDate = date
  ? date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : null;
---

<a
  href={href}
  class="card group block rounded-2xl p-6 no-underline transition-all duration-300 hover:translate-y-[-4px]"
  style={`background: var(--color-cream); border: 1px solid color-mix(in srgb, ${accentColor} 15%, transparent); box-shadow: 0 2px 8px color-mix(in srgb, var(--color-navy) 5%, transparent);`}
>
  <div class="flex items-start gap-3">
    {emoji && <span class="text-2xl shrink-0">{emoji}</span>}
    <div class="flex-1 min-w-0">
      <h3
        class="text-lg font-bold transition-colors duration-200"
        style={`font-family: var(--font-display); color: var(--color-navy); group-hover:color: ${accentColor};`}
      >
        {title}
      </h3>

      <p
        class="mt-1 text-sm line-clamp-2"
        style="color: color-mix(in srgb, var(--color-navy) 55%, transparent); font-family: var(--font-body);"
      >
        {description}
      </p>

      <div class="mt-3 flex flex-wrap items-center gap-2">
        {formattedDate && (
          <span class="text-xs" style="color: color-mix(in srgb, var(--color-navy) 35%, transparent);">
            {formattedDate}
          </span>
        )}
        {tags.map((tag) => (
          <span
            class="rounded-full px-2 py-0.5 text-xs"
            style={`background: color-mix(in srgb, ${accentColor} 10%, transparent); color: ${accentColor};`}
          >
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
