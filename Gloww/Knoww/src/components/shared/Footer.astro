---
const base = import.meta.env.BASE_URL;
---

<footer class="py-12 px-6 text-center">
  <div class="max-w-2xl mx-auto space-y-4">
    <p class="text-sm" style="color: color-mix(in srgb, var(--color-navy) 40%, transparent);">
      made with too much coffee & curiosity ☕✨
    </p>
    <div class="flex items-center justify-center gap-4 text-xs" style="color: color-mix(in srgb, var(--color-navy) 30%, transparent);">
      <a
        href="https://github.com/CloverX4"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-[var(--color-coral)]"
      >
        github
      </a>
      <span>·</span>
      <a
        href="https://linkedin.com/in/indira-nandepu"
        target="_blank"
        rel="noopener"
        class="transition-colors hover:text-[var(--color-coral)]"
      >
        linkedin
      </a>
      <span>·</span>
      <a href={`${base}lets-talk/`} class="transition-colors hover:text-[var(--color-coral)]">
        say hi!!
      </a>
    </div>
  </div>
</footer>
