---
// Wraps content with a fade-up reveal on load
---
<div class="page-transition-wrapper" style="opacity: 0; transform: translateY(24px);">
  <slot />
</div>

<script>
  import { gsap } from 'gsap';

  const wrapper = document.querySelector('.page-transition-wrapper');
  if (wrapper) {
    gsap.to(wrapper, {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power2.out',
      delay: 0.1,
    });
  }
</script>
