---
import SectionLayout from '../layouts/SectionLayout.astro';
import SectionHeading from '../components/shared/SectionHeading.astro';
import { timeline, toolkit, drives, nudge } from '../data/about';

const base = import.meta.env.BASE_URL;
---

<SectionLayout title="About" description="the whole story // engineer, product thinker, forever curious">
  <SectionHeading
    label="about"
    title="so, who am i? (professionally?)"
    subtitle="so here's the whole thing"
    labelColor="var(--color-coral)"
  />

  <!-- Heads-up nudge -->
  <div class="mt-6 mb-2 flex items-center gap-3 rounded-xl px-4 py-3" style="background: color-mix(in srgb, var(--color-peach) 50%, transparent); border: 1px solid color-mix(in srgb, var(--color-peach) 40%, transparent);">
    <span class="text-sm" style="color: color-mix(in srgb, var(--color-navy) 55%, transparent); font-family: var(--font-body);">
      {nudge.text}
      <a href={`${base}${nudge.linkPath}`} class="font-medium no-underline" style="color: var(--color-coral);"> {nudge.linkText}</a>
    </span>
  </div>

  <div class="space-y-12 mt-8">
    <!-- Intro -->
    <section>
      <p class="text-lg leading-relaxed" style="color: color-mix(in srgb, var(--color-navy) 70%, transparent);">
        hey!! i'm <strong style="color: var(--color-coral);">Indira Nandepu</strong>, a software engineer
        who accidentally fell in love with product thinking. currently building things at
        <strong>GEP Worldwide</strong> in Hyderabad, but honestly?? i spend half my time
        thinking about <em>why</em> we're building things rather than just <em>how</em>.
      </p>
    </section>

    <!-- Timeline -->
    <section>
      <h2 class="text-2xl font-bold mb-8" style="font-family: var(--font-display); color: var(--color-navy);">
        the journey so far
      </h2>

      <div class="relative space-y-8 pl-8" style="border-left: 2px solid color-mix(in srgb, var(--color-teal) 30%, transparent);">
        {timeline.map((entry) => (
          <div class="timeline-node relative">
            <div class="absolute -left-[calc(2rem+5px)] top-1 h-3 w-3 rounded-full" style={`background: ${entry.color};`}></div>
            <span class="text-xs font-medium tracking-wider uppercase" style={`color: ${entry.color};`}>{entry.dateRange}</span>
            <h3 class="text-lg font-bold mt-1" style="font-family: var(--font-display);">{entry.title}</h3>
            <p class="text-sm mt-1" style="color: color-mix(in srgb, var(--color-navy) 55%, transparent);">
              {entry.summary}
            </p>

            {entry.pun && (
              <p class="pun-thing text-sm italic mt-2" style={`color: color-mix(in srgb, ${entry.color} 70%, var(--color-navy));`}
                data-pun={entry.pun}
              ></p>
            )}

            {entry.details && entry.details.length > 0 && (
              <details class="timeline-details mt-3">
                <summary class="timeline-toggle text-xs font-medium cursor-pointer" style={`color: ${entry.color};`}>
                  <span class="toggle-open">full story ↓</span><span class="toggle-close">↑ collapse</span>
                </summary>
                <div class="timeline-expand mt-3 space-y-3 pl-3" style={`border-left: 2px solid color-mix(in srgb, ${entry.color} 15%, transparent);`}>
                  <div class="text-sm space-y-2" style="color: color-mix(in srgb, var(--color-navy) 60%, transparent);">
                    {entry.details.map((detail) => (
                      <p>
                        <strong style="color: var(--color-navy);">{detail.label}</strong> · {detail.text}
                        {detail.link && (
                          <a href={`${base}${detail.link.href}`} class="inline-block ml-1 text-xs font-medium no-underline" style="color: var(--color-coral);">{detail.link.text}</a>
                        )}
                      </p>
                    ))}
                  </div>
                </div>
              </details>
            )}
          </div>
        ))}
      </div>
    </section>

    <!-- Toolkit -->
    <section>
      <h2 class="text-2xl font-bold mb-6" style="font-family: var(--font-display); color: var(--color-navy);">
        the toolkit
      </h2>
      <div class="flex flex-wrap gap-2">
        {toolkit.map((skill) => (
          <span
            class="skill-tag px-3 py-1.5 text-xs font-medium rounded-full"
            style={`background: color-mix(in srgb, ${skill.accent} 12%, transparent); color: color-mix(in srgb, ${skill.accent} 85%, var(--color-navy)); border: 1px solid color-mix(in srgb, ${skill.accent} 20%, transparent); font-family: var(--font-body);`}
          >
            {skill.label}
          </span>
        ))}
      </div>
    </section>

    <!-- What drives me -->
    <section>
      <h2 class="text-2xl font-bold mb-4" style="font-family: var(--font-display); color: var(--color-navy);">
        what drives me
      </h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {drives.map((item) => (
          <div
            class="flex items-center gap-3 rounded-xl p-4"
            style="background: color-mix(in srgb, var(--color-peach) 40%, transparent);"
          >
            <span class="text-xl">{item.emoji}</span>
            <span class="text-sm" style="font-family: var(--font-body); color: color-mix(in srgb, var(--color-navy) 70%, transparent);">
              {item.text}
            </span>
          </div>
        ))}
      </div>
    </section>
  </div>
</SectionLayout>

<style>
  .timeline-details summary {
    list-style: none;
    user-select: none;
  }
  .timeline-details summary::-webkit-details-marker {
    display: none;
  }
  .timeline-details .toggle-close {
    display: none;
  }
  .timeline-details[open] .toggle-open {
    display: none;
  }
  .timeline-details[open] .toggle-close {
    display: inline;
    opacity: 0.5;
  }
  .timeline-details .timeline-expand {
    animation: expandIn 0.3s ease-out;
  }
  @keyframes expandIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .pun-thing {
    min-height: 1.8em;
    font-family: var(--font-body);
  }
  .pun-thing::after {
    content: '|';
    animation: blink 0.6s step-end infinite;
    margin-left: 1px;
    font-weight: bold;
  }
  .pun-thing.typed::after {
    animation: blink 0.6s step-end 3;
    opacity: 0;
    animation-fill-mode: forwards;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.timeline-node').forEach((node, i) => {
    gsap.from(node, {
      x: -30,
      opacity: 0,
      duration: 0.5,
      delay: i * 0.15,
      scrollTrigger: { trigger: node, start: 'top 80%' },
    });
  });

  // Pun thing typewriter
  document.querySelectorAll('.pun-thing').forEach((el) => {
    const text = (el as HTMLElement).dataset.pun || '';
    let typed = false;

    ScrollTrigger.create({
      trigger: el,
      start: 'top 85%',
      onEnter: () => {
        if (typed) return;
        typed = true;
        let i = 0;
        const speed = 35;
        function type() {
          if (i <= text.length) {
            (el as HTMLElement).textContent = text.slice(0, i);
            i++;
            setTimeout(type, speed);
          } else {
            el.classList.add('typed');
          }
        }
        type();
      },
    });
  });

  // Skill tags stagger
  document.querySelectorAll('.skill-tag').forEach((tag, i) => {
    gsap.from(tag, {
      opacity: 0, scale: 0.8, duration: 0.3,
      delay: i * 0.04,
      ease: 'back.out(1.5)',
      scrollTrigger: { trigger: tag, start: 'top 90%' },
    });
  });
</script>
